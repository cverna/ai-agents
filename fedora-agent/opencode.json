{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-flash-free",
  "mcp": {
    "gitea-mcp": {
      "enabled": true,
      "type": "local",
      "command": [
        "gitea-mcp",
        "-t", "stdio",
        "-H", "https://forge.fedoraproject.org"
      ]
    }
  },
  "plugin": [["webfetch-ua", { "userAgent": "FedoraAgent/1.0" }]],
  "permission": {
    "external_directory": {
      "/tmp/*": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.config/*": "deny",
      "~/.config/opencode/*": "allow",
      "/run/secrets/*": "deny",
      "/run/gitea-secrets/*": "deny"
    },
    "bash": {
      "env": "deny",
      "env *": "deny",
      "printenv": "deny",
      "printenv *": "deny"
    },
    "skill": {
      "*": "allow"
    }
  }
}
