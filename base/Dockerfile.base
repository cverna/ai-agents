FROM quay.io/fedora/fedora:44

ARG TARGETARCH

LABEL org.opencontainers.image.title="AI Agents Base"
LABEL org.opencontainers.image.description="Minimal base image for AI agents"
LABEL org.opencontainers.image.source="https://github.com/cverna/ai-agents"

RUN dnf install -y --setopt=install_weak_deps=False \
    jq yq git curl tar uv ripgrep podman-remote gh glab koji bodhi-client \
    nodejs npm \
    && dnf clean all && rm -rf /var/cache/dnf

RUN ln -s /usr/bin/podman-remote /usr/local/bin/podman

COPY scripts/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

RUN uv pip install --system skillsaw
RUN npm i -g hunkdiff && npm i -g opencode-ai@latest

RUN mkdir -p /opt/opencode-skills/skillsaw-onboard /opt/opencode-skills/skillsaw-fix && \
    curl -fsSL "https://raw.githubusercontent.com/stbenjam/skillsaw/refs/heads/main/.agents/skills/skillsaw-onboard/SKILL.md" \
         -o /opt/opencode-skills/skillsaw-onboard/SKILL.md && \
    curl -fsSL "https://raw.githubusercontent.com/stbenjam/skillsaw/refs/heads/main/.agents/skills/skillsaw-fix/SKILL.md" \
         -o /opt/opencode-skills/skillsaw-fix/SKILL.md

RUN useradd -m -u 1000 -s /bin/bash agent && \
    mkdir -p /home/agent/.config /home/agent/.local /workspace && \
    chown -R agent:agent /home/agent /workspace

WORKDIR /workspace
USER agent

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["opencode"]
